# 数据库配置 (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@ep-cool-name-123456.us-east-2.aws.neon.tech/thrivex?sslmode=require"

# JWT 配置
JWT_SECRET="yuyang"
JWT_EXPIRES_IN="259200000"

# 服务端口
PORT=9002

# 文件上传配置
FILE_UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760

# 限流配置
RATE_LIMIT_TOKENS=100
RATE_LIMIT_DURATION=60
BLACKLIST_THRESHOLD=10
BLACKLIST_DURATION=60

# CORS 配置
CORS_ORIGIN="http://localhost:9000,http://localhost:9001,https://liuyuyang.net"

# 邮件配置
SMTP_HOST="smtp.qq.com"
SMTP_PORT=465
SMTP_USER="your-email@qq.com"
SMTP_PASS="your-auth-code"

# 环境
NODE_ENV="development"
